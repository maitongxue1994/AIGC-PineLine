# 本地 wrangler dev 用的密钥模板
# 复制为 .dev.vars 并填入真实值（.dev.vars 已被 .gitignore 忽略）

# 上游模型
MINIMAX_API_KEY=
GEMINI_API_KEY=

# 滥用防护（可选）
# 设了之后，前端必须在请求头带 X-Pineline-Auth 才能调 /api/*；
# 前端构建时把同样的值放到 VITE_PINELINE_API_KEY 环境变量
PINELINE_API_KEY=

# 来源白名单（可选，逗号分隔；为空则不校验 Origin）
# 例：PINELINE_ALLOWED_ORIGINS=https://aigcpineline0419.mys2388212.workers.dev,http://localhost:8787
PINELINE_ALLOWED_ORIGINS=
